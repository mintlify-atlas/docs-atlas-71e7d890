  "keyFeatures": [
    "BM25/FTS-backed ranked search with Tree-sitter parsing",
    "Shadow workspace transactions for safe code mutation",
    "Graph-aware dependency and call analysis",
    ".curd script language for repeatable workflows",
    "Profile-based capability gating and runtime ceilings",
    "Model Context Protocol (MCP) server for agent integration",
    "Plugin system for language and tool extensions",
    "Multi-language support (Rust, Python, JavaScript, TypeScript, Go, C/C++, Java)"
  ],
  "publicApiSurface": [
    "curd init",
    "curd search <query>",
    "curd read <uri>",
    "curd edit <uri>",
    "curd graph <uri>",
    "curd workspace begin|commit|rollback|diff",
    "curd run <script.curd>",
